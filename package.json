{
  "name": "sentinai-core",
  "version": "1.0.1",
  "description": "The open-source core AI security engine for SentinAI.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "bin": {
    "sentinai": "dist/scan.js"
  },
  "scripts": {
    "build": "tsc && cp -r src/data dist/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "benchmark": "ts-node src/benchmark.ts",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.71",
    "@ai-sdk/google": "^3.0.64",
    "@ai-sdk/google-vertex": "^4.0.112",
    "@ai-sdk/openai": "^3.0.53",
    "@octokit/rest": "^21.1.1",
    "ai": "^6.0.168",
    "chalk": "^4.1.2"
  },
  "devDependencies": {
    "dotenv": "^16.4.7",
    "ts-node": "^10.9.2",
    "@types/node": "^22.13.14",
    "typescript": "^5.8.2",
    "vitest": "^4.1.4"
  }
}
